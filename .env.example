# ── Reltime Blockchain ──────────────────────────────
RELTIME_RPC_URL=https://mainnet.reltime.com/
RELTIME_CHAIN_ID=32323

# Deployed VehicleCompliance contract address
CONTRACT_ADDRESS=0x...

# Deployer / admin wallet private key (holds DEFAULT_ADMIN_ROLE)
DEPLOYER_PRIVATE_KEY=0x...

# ── Auth ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# ── Wallet Encryption (AES-256-GCM) ────────────────
# Must be 64 hex chars (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── IPFS / Pinata ───────────────────────────────────
PINATA_JWT=your-pinata-jwt-token-here

# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ── Database ────────────────────────────────────────
DB_PATH=./data/magna-caas.db

# ── CORS ────────────────────────────────────────────
# Comma-separated origins (leave blank for wildcard)
# CORS_ORIGINS=https://your-domain.com
